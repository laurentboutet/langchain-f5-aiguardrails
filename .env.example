# F5 AI Guardrails Configuration
# Copy this file to .env and fill in your values

# ============================================================
# REQUIRED — both middleware and inline proxy modes
# ============================================================

# Your F5 AI Guardrails (CalypsoAI) API key
F5_GUARDRAIL_API_KEY=your-api-key-here

# Base URL for your F5 AI Guardrails instance
# Examples: https://us1.calypsoai.app  https://eu1.calypsoai.app
F5_GUARDRAIL_BASE_URL=https://us1.calypsoai.app

# ============================================================
# INLINE PROXY MODE — ChatF5OpenAI (examples/07_inline_openai.py)
# ============================================================

# Provider name for OpenAI-compatible models via F5 proxy
# This is the CalypsoAI provider slug configured in your deployment
# Example: openai-gpt4, my-openai-provider
# F5_GUARDRAIL_PROVIDER_OPENAI=your-openai-provider-name

# ============================================================
# MIDDLEWARE MODE — F5GuardrailMiddleware (examples/01-06)
# ============================================================

# Optional: Default project ID or friendly ID for scans
# F5_GUARDRAIL_PROJECT=my-project

# Optional: Enforcement mode (enforce | monitor | off). Default: enforce
# F5_GUARDRAIL_MODE=enforce

# Optional: Allow requests when scan API is unreachable (true | false). Default: true
# F5_GUARDRAIL_FAIL_OPEN=true

# Optional: HTTP timeout in seconds. Default: 30
# F5_GUARDRAIL_TIMEOUT=30

# Optional: Log verbose scanner details in callbacks (true | false). Default: false
# F5_GUARDRAIL_VERBOSE=false

# ============================================================
# OPTIONAL — examples that use a real LLM (examples/01, 05)
# ============================================================

# OpenAI API key (only needed when uncommenting agent code in examples/01 and 05)
# OPENAI_API_KEY=your-openai-api-key-here
